{
  "name": "att",
  "version": "1.0.0",
  "description": "ZKTeco attendance device integration",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "bun run app.ts",
    "gui": "bun run --filter @graphland/zk-gui dev",
    "gui:build": "bun run --filter @graphland/zk-gui build:app",
    "typecheck": "bun run --filter @graphland/zk-client typecheck",
    "test": "bun run --filter @graphland/zk-client test"
  },
  "dependencies": {
    "@graphland/zk-client": "workspace:*"
  }
}
