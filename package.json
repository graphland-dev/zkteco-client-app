{
  "name": "att",
  "version": "1.0.0",
  "description": "ZKTeco attendance device integration",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "bun run app.ts",
    "dev": "bun run --filter @graphland/zk-gui dev",
    "gui": "bun run --filter @graphland/zk-gui dev",
    "build": "bun run scripts/build.mjs",
    "build:fast": "bun run scripts/build.mjs -- --skip-typecheck --skip-tests",
    "gui:build": "bun run --filter @graphland/zk-gui build:app",
    "typecheck": "bun run --filter @graphland/zkteco typecheck && bun run --filter @graphland/zk-gui typecheck",
    "test": "bun run --filter @graphland/zkteco test"
  },
  "dependencies": {
    "@graphland/zkteco": "workspace:*"
  }
}
