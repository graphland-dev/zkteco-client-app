{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Graphland ZKT Client",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:tray:default",
    "autostart:default",
    "log:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/zk-sidecar",
          "sidecar": true
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "bun",
          "cmd": "bun",
          "args": true
        }
      ]
    }
  ]
}
